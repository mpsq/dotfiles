[Unit]
Description=Kanshi display configuration daemon
PartOf=graphical-session.target
After=graphical-session.target noctalia.service

[Service]
Type=simple
ExecStartPre=%h/.local/bin/kanshi-delay
ExecStart=/usr/bin/kanshi
KillSignal=SIGINT
Restart=on-failure
RestartSec=1
TimeoutStopSec=2

[Install]
WantedBy=graphical-session.target
