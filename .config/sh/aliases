#!/usr/bin/env bash

alias grep="grep --color=auto"
alias egrep="grep -E --color=auto"
alias fgrep="grep -F --color=auto"

alias ls="eza"
alias l="eza -lh --classify --icons=auto"
alias la="eza -lah --classify --icons=auto"
alias lsd="eza -l --classify --only-dirs --icons=auto"

alias vgit="vcsh dotfiles"
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."

alias em="emacs"
alias emc="emacsclient -t -a=vi"

alias k="kubectl"
alias vim="emc"

alias sway="exec systemd-cat --identifier=sway sway"
