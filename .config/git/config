  name = Méril Pilon
  email = me@mpsq.org
  signingkey = EE8E8E2157EE310C

[github]
  user = mpsq

[gitlab]
  user = mpsq

[core]
  autocrlf = input
  editor = emacsclient -t

[diff]
  algorithm = histogram
  colorMoved = default
  colorMovedWS = allow-indentation-change
  mnemonicPrefix = true
  submodule = log
  renames = copies

[merge]
  conflictstyle = zdiff3
  commit = no

[pager]
  diff = delta --relative-paths
  log = delta --relative-paths
  reflog = delta --relative-paths
  show = delta --relative-paths

[interactive]
  diffFilter = delta --relative-paths --line-numbers --color-only --features=interactive

[delta "interactive"]
  keep-plus-minus-markers = false

[delta]
  commit-decoration-style = bold ol dim yellow
  features = line-numbers decorations
  file-decoration-style = brightyellow ul ol
  file-style = brightyellow
  hunk-header-decoration-style = purple box
  whitespace-error-style = 22 reverse
  hunk-header-style = file line-number syntax
  navigate = true
  hyperlinks = true

[log]
  date = short
  decorate = auto

[format]
  pretty = %C(Yellow)%h  %C(reset)%ad (%C(Green)%cr%C(reset))%x09 %C(Cyan)%an: %C(reset)%s

[feature]
  manyFiles = true

[push]
  autoSetupRemote = true
  useForceIfIncludes = true

[alias]
  # misc
  ci = commit
  s = status
  a = add
  aa = add --all
  d = diff

  # branch
  b = branch
  co = checkout
  l = log --oneline -20
  unstage = reset HEAD --
  sw = switch
  rs = restore
  cp = cherry-pick

[commit]
  gpgsign = true

[rebase]
  autoStash = true
  stat = true
  updateRefs = true

[pull]
  rebase = true

[tag]
  sort = -version:refname
  gpgsign = true

[transfer]
  fsckObjects = true

[status]
  submoduleSummary = true

[submodule]
  recurse = true

[fetch]
  prune = true
  writeCommitGraph = true
  fsckObjects = true

[receive]
  fsckObjects = true

[branch]
  sort = -committerdate

[rerere]
  enabled = true
  autoUpdate = true

[column]
  ui = auto

[include]
  path = ~/.config/git/host

[url "git@github.com:"]
  insteadOf = gh:

[maintenance]
  auto = true

[init]
  defaultBranch = main

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
