[screencast]
max_fps=30
chooser_type=dmenu
chooser_cmd=fuzzel --dmenu --width 65
force_mod_linear=1
exec_before=sh -c "notify-send --urgency=normal --app-name=xdpw \"Screenshare started\" && sleep 1 && makoctl mode -s do-not-disturb"
exec_after=sh -c "makoctl mode -s default && notify-send --urgency=normal --app-name=xdpw \"Screenshare ended\""
