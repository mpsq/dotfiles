### Variables
#
set $mod Mod1
set $term foot
set $left h
set $down j
set $up k
set $right l

# System defaults (environment setup, etc.) -- must come before user settings
include /etc/sway/config.d/*

font pango:monospace 9

# Theme colors defined in ~/.config/sway/noctalia

gaps inner 6
gaps outer 0
# Slightly thicker borders.
default_border pixel 2
default_floating_border pixel 2
# Hide borders if window is child in a workspace or container.
hide_edge_borders --i3 smart
titlebar_padding 6 6
popup_during_fullscreen smart

### Input/output
#
input type:keyboard {
  xkb_layout gb
}

input type:pointer {
  accel_profile flat
}

input type:touchpad {
  drag enabled
  dwt enabled
  tap enabled
  natural_scroll enabled
  middle_emulation enabled
  accel_profile flat
  pointer_accel 0.12
}

seat * xcursor_theme Adwaita 24

## XWayland
#
xwayland disable

### Focus settings
#
focus_on_window_activation smart

### Key bindings
#
set $ipc qs -c noctalia-shell ipc call

#
# Basics:
#
bindsym $mod+Return exec $term
bindsym $mod+Shift+q kill
bindsym $mod+Shift+c reload; exec notify-send -t 2000 "sway" "Config reloaded"
floating_modifier $mod normal

#
# Moving around:
#
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

#
# Workspaces:
#
bindsym $mod+1 workspace 1
bindsym $mod+2 workspace 2
bindsym $mod+3 workspace 3
bindsym $mod+4 workspace 4
bindsym $mod+5 workspace 5
bindsym $mod+6 workspace 6
bindsym $mod+7 workspace 7
bindsym $mod+8 workspace 8
bindsym $mod+9 workspace 9

bindsym $mod+Shift+1 move container to workspace 1
bindsym $mod+Shift+2 move container to workspace 2
bindsym $mod+Shift+3 move container to workspace 3
bindsym $mod+Shift+4 move container to workspace 4
bindsym $mod+Shift+5 move container to workspace 5
bindsym $mod+Shift+6 move container to workspace 6
bindsym $mod+Shift+7 move container to workspace 7
bindsym $mod+Shift+8 move container to workspace 8
bindsym $mod+Shift+9 move container to workspace 9

bindsym $mod+Control+Shift+$right move workspace to output right
bindsym $mod+Control+Shift+$left move workspace to output left
bindsym $mod+Control+Shift+$down move workspace to output down
bindsym $mod+Control+Shift+$up move workspace to output up

#
# Layout stuff:
#
bindsym $mod+t splith
bindsym $mod+v splitv

bindsym $mod+f fullscreen toggle

bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

bindsym $mod+a focus parent
bindsym $mod+c focus child

#
# Scratchpad:
#
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

#
# Resizing containers:
#
mode "resize" {
    bindsym $left resize shrink width 15px
    bindsym $down resize grow height 15px
    bindsym $up resize shrink height 15px
    bindsym $right resize grow width 15px

    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

#
# Custom:
#
# Audio controls
bindsym --locked Shift+Ctrl+ISO_Level3_Shift exec volume-down
bindsym --locked Shift+Ctrl+Super_R exec volume-up
bindsym --locked XF86AudioLowerVolume exec volume-down
bindsym --locked XF86AudioRaiseVolume exec volume-up
bindsym --locked XF86AudioMute exec audio-toggle
bindsym --locked XF86AudioPlay exec $ipc media playPause
bindsym --locked XF86AudioPause exec $ipc media playPause
bindsym --locked XF86AudioNext exec $ipc media next
bindsym --locked XF86AudioPrev exec $ipc media previous
# Screen brightness
bindsym --locked XF86MonBrightnessUp exec $ipc brightness increase
bindsym --locked XF86MonBrightnessDown exec $ipc brightness decrease

# Lock
bindsym Ctrl+Shift+Super_L exec $ipc sessionMenu lock
bindswitch --locked lid:on exec $ipc sessionMenu lock

# Screenshot
bindsym $mod+Shift+u exec capture-screen
bindsym $mod+Shift+v exec capture-screen video

# Launcher
bindsym $mod+d exec $ipc launcher toggle
bindsym $mod+Shift+e exec $ipc sessionMenu toggle

# Notifications
bindsym $mod+Shift+n exec makoctl dismiss --all

# Gestures
bindgesture swipe:3:right workspace prev
bindgesture swipe:3:left workspace next
bindgesture swipe:3:up fullscreen enable
bindgesture swipe:3:down fullscreen disable

# Setup headless output for screensharing
output HEADLESS-1 resolution 1920x1080
output HEADLESS-1 enable
workspace 9 output HEADLESS-1
bindsym $mod+0 workspace number 0
bindsym $mod+Shift+0 move container to workspace number 0

### Application specific settings
for_window [app_id="nm-connection-editor"] floating enable
for_window [app_id="org.gnome.Calculator"] floating enable
for_window [app_id="gcr-prompter"] floating enable, opacity 0.90
for_window [title = "Picture-in-Picture"] floating enable
for_window [app_id="(pwvucontrol|pavucontrol)"] floating enable
for_window [app_id="firefox" title="Firefox — Sharing Indicator"] floating enable
for_window [app_id="firefox" title="Picture-in-Picture"] floating enable
for_window [app_id="firefox" title="About Mozilla Firefox"] floating enable
for_window [app_id="firefox" title="MetaMask"] floating enable

### Assign
assign [app_id = "emacs"] 2
assign [app_id = "spotify"] 4

# prevent idle state at fullscreen mode for some apps
for_window [app_id="google-chrome"] inhibit_idle fullscreen
for_window [app_id="firefox"] inhibit_idle fullscreen
for_window [app_id="firefox-developer-edition"] inhibit_idle fullscreen

### Session
include ~/.config/sway/noctalia

exec swaymsg create_output && systemctl --user reset-failed && systemctl --user start sway-session.target
exec (swaymsg -t subscribe '["shutdown"]' || true) && systemctl --user stop graphical-session.target
