#!/usr/bin/env bash
set -euo pipefail

arg="${1:-instant}"

mkdir -p "$HOME/instants"

if [[ "$arg" == "video" ]]; then
  if pgrep wf-recorder >/dev/null; then
    pkill -SIGINT wf-recorder
    for _i in {1..100}; do pgrep -x wf-recorder >/dev/null || break; sleep 0.1; done
    notify-send --urgency=normal --app-name=wf-recorder "Screen capture ended"
  else
    now=$(date +'%Y-%m-%d-%H%M%S')
    region="$(slurp)" || exit 0

    wf-recorder -g "$region" -f "$HOME/instants/$now.mp4" -x yuv420p &
    for _i in {1..50}; do pgrep -x wf-recorder >/dev/null && break; sleep 0.1; done
  fi
else
  dulcepan - | swappy -f -
fi
