#!/usr/bin/env bash
set -euo pipefail

arg="${1:-instant}"

screenshots_dir="${XDG_SCREENSHOTS_DIR:-$HOME/instants}"
mkdir -p "$screenshots_dir"

if [[ "$arg" == "video" ]]; then
  if pgrep wf-recorder >/dev/null; then
    pkill -SIGINT wf-recorder
    for _i in {1..100}; do
      pgrep -x wf-recorder >/dev/null || break
      sleep 0.1
    done
    notify-send --urgency=normal --app-name=wf-recorder "Screen capture ended"
  else
    now=$(date +'%Y-%m-%d-%H%M%S')
    region="$(slurp)" || exit 0

    wf-recorder -g "$region" -f "$screenshots_dir/$now.mp4" &
    for _i in {1..50}; do
      pgrep -x wf-recorder >/dev/null && break
      sleep 0.1
    done
  fi
else
  OUT=$(swaymsg -t get_outputs | jq -r ".[] | select(.focused) | .name")
  grim -o "$OUT" -t jpeg -q 95 /tmp/satty-shot.jpg
  GDK_BACKEND=wayland GTK_USE_PORTAL=0 satty --filename /tmp/satty-shot.jpg
fi
