#!/usr/bin/env bash
set -euo pipefail

DUMPS_DIR=${XDG_CONFIG_HOME:-$HOME/.config}/dconf/

CONFIGS=(
  /org/gnome/desktop/interface
  /org/gnome/desktop/privacy
  /org/gtk/settings/file-chooser
)

for CONFIG in "${CONFIGS[@]}"; do
  FILENAME="${CONFIG//\//.}"
  FILENAME="${FILENAME#.}"
  dconf dump "$CONFIG"/ >"$DUMPS_DIR/$FILENAME.conf"
done
