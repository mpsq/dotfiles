#!/usr/bin/env bash
set -euo pipefail

laptop_output="eDP-1"

# 1. Pick the first enabled non-eDP, non-HEADLESS output
target_output=$(swaymsg -t get_outputs -r | jq -r '.[] | select((.name | test("^(eDP|HEADLESS)") | not)) | .name' | head -n1)
target_output="${target_output:-$laptop_output}"

# 2. Filter workspaces:
# - Not a scratchpad (.num != -1)
# - Has windows/content (.focus != [])
# - IS NOT already on the target output (.output != $target_output)
workspaces=$(swaymsg -t get_workspaces -r | jq -r --arg target "$target_output" \
  '.[] | select(.num != -1 and .focus != [] and .output != $target) | .name')

# 3. Move only the remaining candidates
[[ -z "$workspaces" ]] && { swaymsg workspace 1; exit 0; }
readarray -t ws_array <<< "$workspaces"
for ws in "${ws_array[@]}"; do
  [[ -z "$ws" ]] && continue
  swaymsg "workspace \"$ws\"; move workspace to output \"$target_output\"" &>/dev/null || true
  echo "Moved workspace: $ws"
done

swaymsg workspace 1
